/* miniprogram/pages/admin/scores/scores.wxss */
.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 30rpx;
}

/* 统计卡片 */
.stats-section {
  display: flex;
  padding: 30rpx;
  gap: 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.stats-card {
  flex: 1;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  text-align: center;
}

.stats-num {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: white;
}

.stats-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 10rpx;
}

/* 操作按钮 */
.action-bar {
  display: flex;
  padding: 30rpx;
  gap: 20rpx;
  flex-wrap: wrap;
}

.action-btn {
  flex: 1;
  min-width: 200rpx;
  height: 80rpx;
  background: white;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.05);
}

.export-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.export-btn text {
  color: white;
}

.copy-btn {
  background: #4caf50;
  color: white;
}

.copy-btn text {
  color: white;
}

.clear-btn {
  background: #fff5f5;
  color: #e53935;
}

.clear-btn text {
  color: #e53935;
}

/* 成绩列表 */
.records-section {
  padding: 0 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.record-item {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.05);
}

.record-info {
  flex: 1;
}

.record-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.record-phone {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

.record-time {
  display: block;
  font-size: 24rpx;
  color: #ccc;
  margin-top: 8rpx;
}

.record-score {
  text-align: center;
  margin: 0 20rpx;
}

.score-num {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #667eea;
}

.score-label {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.record-grade {
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-right: 20rpx;
}

/* 等级样式 - 用英文类名 */
.grade-excellent {
  background: #e8f5e9;
  color: #2e7d32;
}

.grade-good {
  background: #e3f2fd;
  color: #1565c0;
}

.grade-medium {
  background: #fff3e0;
  color: #ef6c00;
}

.grade-pass {
  background: #fff8e1;
  color: #f9a825;
}

.grade-fail {
  background: #ffebee;
  color: #c62828;
}

.delete-btn {
  padding: 10rpx 20rpx;
  background: #fff5f5;
  border-radius: 10rpx;
}

.delete-btn text {
  font-size: 24rpx;
  color: #e53935;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  background: white;
  border-radius: 20rpx;
  padding: 50rpx;
  text-align: center;
}

.modal-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.modal-text {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.modal-btns {
  display: flex;
  gap: 30rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.modal-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.modal-btn.confirm {
  background: #e53935;
  color: white;
}
