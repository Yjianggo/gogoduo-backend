<!--miniprogram/pages/admin/scores/scores.wxml-->
<view class="container">
  <!-- 顶部统计 -->
  <view class="stats-section">
    <view class="stats-card">
      <text class="stats-num">{{totalStudents}}</text>
      <text class="stats-label">考试人数</text>
    </view>
    <view class="stats-card">
      <text class="stats-num">{{averageScore}}</text>
      <text class="stats-label">平均分</text>
    </view>
    <view class="stats-card">
      <text class="stats-num">{{passRate}}%</text>
      <text class="stats-label">及格率</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-bar">
    <button class="action-btn export-btn" bindtap="exportExcel">
      <text>导出Excel</text>
    </button>
    <button class="action-btn copy-btn" bindtap="copyToClipboard">
      <text>复制成绩单</text>
    </button>
    <button class="action-btn clear-btn" bindtap="clearAll" wx:if="{{records.length > 0}}">
      <text>清空记录</text>
    </button>
  </view>

  <!-- 成绩列表 -->
  <view class="records-section">
    <view class="section-title">成绩明细</view>
    
    <view class="empty-tip" wx:if="{{records.length === 0}}">
      <text>暂无考试记录</text>
    </view>

    <view class="record-item" wx:for="{{records}}" wx:key="index">
      <view class="record-info">
        <text class="record-name">{{item.name}}</text>
        <text class="record-phone">{{item.phone}}</text>
        <text class="record-time">{{item.submitTime}}</text>
      </view>
      <view class="record-score">
        <text class="score-num">{{item.score}}</text>
        <text class="score-label">分</text>
      </view>
      <view class="record-grade grade-{{item.gradeClass}}">
        <text>{{item.grade}}</text>
      </view>
      <view class="delete-btn" bindtap="showDeleteConfirm" data-index="{{index}}">
        <text>删除</text>
      </view>
    </view>
  </view>
</view>

<!-- 删除确认弹窗 -->
<view class="modal-mask" wx:if="{{showModal}}" bindtap="cancelDelete">
  <view class="modal-content" catchtap="">
    <text class="modal-title">确认删除</text>
    <text class="modal-text">确定要删除这条成绩记录吗？</text>
    <view class="modal-btns">
      <button class="modal-btn cancel" bindtap="cancelDelete">取消</button>
      <button class="modal-btn confirm" bindtap="confirmDelete">删除</button>
    </view>
  </view>
</view>
