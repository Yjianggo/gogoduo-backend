/* miniprogram/pages/admin/questions/questions.wxss */
.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 0;
}

/* 顶部导航 */
.nav-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 30rpx 40rpx;
  color: white;
}

.nav-back {
  font-size: 28rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
}

/* 导航栏右侧按钮组 */
.nav-actions {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.nav-action-btn {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  color: white;
  background: rgba(255, 255, 255, 0.2);
}

.nav-action-btn.sort-done {
  background: #10b981;
  font-weight: bold;
}

/* 批量操作工具栏 */
.batch-toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff8e1;
  padding: 20rpx 30rpx;
  border-bottom: 2rpx solid #ffe082;
}

.batch-select-all {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.batch-label {
  font-size: 28rpx;
  color: #333;
}

.batch-delete-btn {
  padding: 14rpx 28rpx;
  border-radius: 30rpx;
  background: #e0e0e0;
  color: #999;
  font-size: 28rpx;
  font-weight: bold;
}

.batch-delete-btn.active {
  background: #f44336;
  color: white;
}

/* 复选框 */
.checkbox {
  width: 42rpx;
  height: 42rpx;
  border: 3rpx solid #bbb;
  border-radius: 8rpx;
  background: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: white;
  flex-shrink: 0;
}

.checkbox.checked {
  background: #667eea;
  border-color: #667eea;
}

/* 排序提示条 */
.sort-hint-bar {
  background: #fffde7;
  border-bottom: 2rpx solid #fff176;
  padding: 18rpx 30rpx;
}

.sort-hint-text {
  font-size: 26rpx;
  color: #f59e0b;
}

/* 题目列表 */
.question-list {
  padding: 30rpx;
  padding-bottom: 220rpx;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.list-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.list-count {
  font-size: 26rpx;
  color: #999;
}

.question-item {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 25rpx;
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

/* 选中状态 */
.question-item.selected {
  background: #f0f4ff;
  border: 2rpx solid #667eea;
}

/* 排序模式左边框 */
.question-item.sort-item {
  border-left: 6rpx solid #667eea;
}

/* 复选框包裹层 */
.item-checkbox-wrap {
  padding-top: 6rpx;
  flex-shrink: 0;
}

/* 排序序号区域 */
.item-sort-handle {
  width: 52rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 4rpx;
}

.sort-num {
  font-size: 28rpx;
  font-weight: bold;
  color: #667eea;
}

/* 题目主体内容 */
.item-main {
  flex: 1;
  min-width: 0;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.item-index {
  font-size: 28rpx;
  color: #667eea;
  font-weight: bold;
}

.item-type {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background: #e8f5e9;
  color: #2e7d32;
}

.item-type-single {
  background: #e3f2fd;
  color: #1565c0;
}

.item-type-judge {
  background: #fff3e0;
  color: #e65100;
}

.item-type-fill {
  background: #fce4ec;
  color: #c2185b;
}

.item-type-essay {
  background: #f3e5f5;
  color: #7b1fa2;
}

.item-content {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 15rpx;
}

.item-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 15rpx;
  border-top: 1rpx solid #f0f0f0;
}

.item-answer {
  font-size: 24rpx;
  color: #666;
  flex: 1;
}

.item-actions {
  display: flex;
  gap: 30rpx;
}

.action-btn {
  font-size: 28rpx;
}

.action-btn.edit {
  color: #667eea;
}

.action-btn.delete {
  color: #f44336;
}

/* 排序按钮组 */
.item-sort-btns {
  display: flex;
  gap: 10rpx;
  align-items: center;
  flex-shrink: 0;
}

.sort-btn-item {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  background: #eef0ff;
  color: #667eea;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
}

.sort-btn-item.top,
.sort-btn-item.bottom {
  font-size: 22rpx;
  background: #f3e5f5;
  color: #764ba2;
}

.sort-btn-item.disabled {
  opacity: 0.25;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 底部按钮 */
.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx 30rpx;
  background: white;
  box-shadow: 0 -5rpx 20rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 按钮行（第一行：导入 + 添加） */
.btn-row {
  display: flex;
  gap: 20rpx;
}

.add-btn, .import-btn {
  flex: 1;
  height: 90rpx;
  border-radius: 45rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 30rpx;
  font-weight: bold;
}

.add-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.import-btn {
  background: #10b981;
}

/* 保存按钮（第二行：单独一行） */
.save-btn {
  height: 88rpx;
  background: #f59e0b;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 30rpx;
  font-weight: bold;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 90%;
  max-height: 85vh;
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 60rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  padding: 30rpx;
  max-height: 60vh;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid #eee;
}

/* 表单 */
.form-group {
  margin-bottom: 25rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 10rpx;
}

.form-input {
  height: 80rpx;
  background: #f8f9fa;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  border: 2rpx solid #e9ecef;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  background: #f8f9fa;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 2rpx solid #e9ecef;
}

.form-hint {
  font-size: 22rpx;
  color: #999;
  margin-top: 10rpx;
  display: block;
}

.picker-value {
  height: 80rpx;
  background: #f8f9fa;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  line-height: 80rpx;
  border: 2rpx solid #e9ecef;
  color: #333;
}

/* 答案选择器 */
.answer-selector {
  display: flex;
  gap: 20rpx;
}

.answer-btn {
  flex: 1;
  height: 80rpx;
  background: #f0f0f0;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
  border: 3rpx solid #e0e0e0;
}

.answer-btn.active {
  background: #667eea;
  border-color: #667eea;
  color: white;
}

/* 弹窗按钮 */
.cancel-btn, .save-btn {
  flex: 1;
  height: 90rpx;
  border-radius: 45rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  margin: 0 15rpx;
}

.cancel-btn {
  background: #f0f0f0;
  color: #666;
}

.save-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

/* 导入弹窗 */
.import-modal {
  max-height: 90vh;
}

.import-intro {
  background: #f0f7ff;
  border-radius: 16rpx;
  padding: 25rpx;
  margin-bottom: 30rpx;
}

.intro-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 15rpx;
}

.intro-text {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 15rpx;
}

.type-list {
  background: white;
  border-radius: 10rpx;
  padding: 20rpx;
}

.type-list text {
  display: block;
  font-size: 24rpx;
  color: #555;
  line-height: 1.8;
}

.template-section {
  margin-top: 20rpx;
}

.template-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.template-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #667eea;
}

.copy-example-btn {
  font-size: 26rpx;
  color: #10b981;
  padding: 8rpx 20rpx;
  background: #e8f5e9;
  border-radius: 20rpx;
}

.template-textarea {
  width: 100%;
  min-height: 400rpx;
  background: #f8f9fa;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 24rpx;
  font-family: monospace;
  box-sizing: border-box;
  border: 2rpx solid #e9ecef;
  line-height: 1.6;
}

.import-confirm-btn {
  flex: 1;
  height: 90rpx;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  border-radius: 45rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 30rpx;
  font-weight: bold;
  margin: 0 15rpx;
}
