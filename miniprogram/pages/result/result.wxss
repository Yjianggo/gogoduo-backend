.container {
  padding: 0;
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.result-header {
  text-align: center;
  padding: 80rpx 0 40rpx;
}

.result-icon {
  display: block;
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.result-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
}

.score-card {
  margin: 0 40rpx 30rpx;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 50rpx;
  text-align: center;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.15);
}

.score-circle {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1890ff 0%, #69c0ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(24, 144, 255, 0.3);
}

.score-inner {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background-color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.score-value {
  font-size: 64rpx;
  font-weight: bold;
  color: #1890ff;
}

.score-label {
  font-size: 28rpx;
  color: #999;
  margin-top: 8rpx;
}

.score-info {
  display: flex;
  justify-content: center;
  align-items: center;
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx;
}

.info-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.info-value.correct {
  color: #52c41a;
}

.info-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: #e8e8e8;
}

.stats-card,
.grade-card {
  margin: 0 40rpx 30rpx;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.1);
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #1890ff;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.grade-display {
  text-align: center;
  padding: 30rpx;
  background-color: #fafafa;
  border-radius: 16rpx;
}

.grade-text {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.grade-text.excellent {
  color: #fa8c16;
}

.grade-text.good {
  color: #52c41a;
}

.grade-text.medium {
  color: #1890ff;
}

.grade-text.pass {
  color: #faad14;
}

.grade-text.fail {
  color: #ff4d4f;
}

.grade-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
}

.action-section {
  padding: 40rpx;
}

.btn-primary {
  background-color: #fff;
  color: #1890ff;
  border-radius: 50rpx;
  padding: 30rpx;
  font-size: 34rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  border: none;
}

.btn-primary::after {
  border: none;
}

.footer {
  text-align: center;
  padding: 40rpx;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}
