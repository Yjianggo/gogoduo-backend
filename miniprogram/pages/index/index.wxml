<!--miniprogram/pages/index/index.wxml-->
<view class="container">
  <!-- 页面标题 -->
  <view class="header">
    <text class="app-title">{{examTitle}}</text>
    <text class="app-subtitle">请输入信息开始答题</text>
  </view>

  <!-- 登录表单 -->
  <view class="login-form">
    
    <!-- 姓名 -->
    <view class="input-group">
      <text class="input-label">姓名</text>
      <input 
        class="input-field" 
        type="text" 
        placeholder="请输入您的姓名"
        placeholder-class="placeholder"
        value="{{name}}"
        bindinput="onNameInput"
      />
    </view>

    <!-- 电话号码 -->
    <view class="input-group">
      <text class="input-label">电话号码</text>
      <input 
        class="input-field" 
        type="number" 
        placeholder="请输入11位手机号码"
        placeholder-class="placeholder"
        maxlength="11"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <!-- 考试须知 -->
    <view class="notice-wrapper">
      <checkbox-group bindchange="onNoticeChange">
        <label class="notice-label">
          <checkbox value="agreed" color="#4a90d9" />
          <text class="notice-text">我已阅读并同意</text>
          <text class="notice-link" bindtap="showNotice">《考试须知》</text>
        </label>
      </checkbox-group>
    </view>

    <!-- 登录按钮 -->
    <button 
      class="login-btn {{canLogin ? '' : 'disabled'}}" 
      bindtap="onLogin"
      disabled="{{!canLogin}}"
    >
      <text class="btn-text">进入考试</text>
    </button>
  </view>

  <!-- 底部信息 -->
  <view class="footer">
    <text class="footer-text">考试时长：{{examDuration || 30}}分钟</text>
  </view>

</view>

<!-- 管理后台入口 - 固定在底部左侧 -->
<navigator url="/pages/admin/index/index" class="admin-fixed-btn" hover-class="none">
  <text class="admin-icon">⚙️</text>
  <text class="admin-text">管理后台</text>
</navigator>
