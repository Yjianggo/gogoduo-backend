<!--miniprogram/pages/login/login.wxml-->
<view class="container">
  <!-- 返回首页按钮 -->
  <view class="back-btn" bindtap="goBack">
    <text class="back-icon">←</text>
  </view>

  <!-- 页面标题 -->
  <view class="header">
    <text class="title">登录考试</text>
    <text class="subtitle">请输入您的考试信息</text>
  </view>

  <!-- 登录表单 -->
  <view class="login-form">
    
    <!-- 学号/工号 -->
    <view class="input-group">
      <text class="input-label">学号/工号</text>
      <input 
        class="input-field" 
        type="text" 
        placeholder="请输入学号或工号"
        placeholder-class="placeholder"
        value="{{studentId}}"
        bindinput="onStudentIdInput"
      />
    </view>

    <!-- 姓名 -->
    <view class="input-group">
      <text class="input-label">姓名</text>
      <input 
        class="input-field" 
        type="text" 
        placeholder="请输入您的姓名"
        placeholder-class="placeholder"
        value="{{name}}"
        bindinput="onNameInput"
      />
    </view>

    <!-- 电话号码 -->
    <view class="input-group">
      <text class="input-label">电话号码</text>
      <input 
        class="input-field" 
        type="number" 
        placeholder="请输入手机号码"
        placeholder-class="placeholder"
        maxlength="11"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <!-- 考试须知 -->
    <view class="notice-wrapper">
      <checkbox-group bindchange="onNoticeChange">
        <label class="notice-label">
          <checkbox value="agreed" color="#4a90d9" />
          <text class="notice-text">我已阅读并同意</text>
          <text class="notice-link" bindtap="showNotice">《考试须知》</text>
        </label>
      </checkbox-group>
    </view>

    <!-- 登录按钮 -->
    <button 
      class="login-btn {{canLogin ? '' : 'disabled'}}" 
      bindtap="onLogin"
      disabled="{{!canLogin}}"
    >
      <text class="btn-text">进入考试</text>
    </button>
  </view>
</view>
