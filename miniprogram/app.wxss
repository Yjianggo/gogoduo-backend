page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  padding: 30rpx;
  min-height: 100vh;
}

.btn-primary {
  background-color: #1890ff;
  color: #fff;
  border-radius: 8rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  text-align: center;
  margin: 20rpx 0;
  border: none;
}

.btn-primary:active {
  background-color: #40a9ff;
}

.btn-secondary {
  background-color: #fff;
  color: #1890ff;
  border-radius: 8rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  text-align: center;
  margin: 20rpx 0;
  border: 2rpx solid #1890ff;
}

.input-group {
  margin-bottom: 30rpx;
}

.input-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
  display: block;
}

.input-field {
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 32rpx;
  background-color: #fff;
}

.card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}
